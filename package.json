{
  "name": "eaem-eds-themes",
  "version": "0.0.2",
  "description": "AEM EDS Themes",
  "license": "MIT License, Copyright 2020 Adobe Systems Incorporated",
  "scripts": {
    "build": "rimraf dist && parcel build src/theme.ts",
    "watch": "parcel watch src/theme.ts",
    "release": "rimraf release && parcel build src/theme.ts --dist-dir release",
    "prepare": "husky"
  },
  "devDependencies": {
    "@adobe/aem-site-theme-builder": "5.2.1",
    "@parcel/transformer-sass": "^2.7.0",
    "autoprefixer": "^10.3.7",
    "browser-sync": "^2.26.13",
    "husky": "^9.0.0",
    "install": "^0.13.0",
    "normalize.css": "^8.0.1",
    "npm": "^8.1.4",
    "npm-run-all": "^4.1.5",
    "parcel": "^2.7.0",
    "parcel-namer-rewrite": "^2.0.0-rc.2",
    "postcss": "^8.3.11",
    "rimraf": "^3.0.2",
    "typescript": "^4.5.2"
  },
  "parcel-namer-rewrite": {
    "chain": "@parcel/namer-default",
    "rules": {
      "(.*?)(\\.[a-f0-9]{8})?\\.(ttf|woff2?)": "resources/fonts/$1.$3",
      "(.*?)(\\.[a-f0-9]{8})?\\.(svg|png|gif|jpg|jpeg|webp)": "resources/images/$1.$3"
    }
  },
  "postcss": {
    "plugins": {
      "autoprefixer": {
        "overrideBrowserslist": [
          "> 1%",
          "last 2 versions"
        ]
      }
    }
  }
}
